---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Better Lives Building Tribes brings people, organizations, and communities together to strengthen relationships, support well-being, and build resilience that lasts.',
  ogImage,
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://betterlivesbuildingtribes.com';

// Primary location (Google requires one LocalBusiness per location)
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'MentalHealthBusiness',
  '@id': `${siteUrl}/#organization`,
  name: 'Better Lives Building Tribes',
  description: 'Better Lives Building Tribes brings people, organizations, and communities together to strengthen relationships, support well-being, and build resilience that lasts.',
  url: siteUrl,
  telephone: '+1-720-295-1508',
  email: 'BetterLives.BuildingTribes@gmail.com',
  image: `${siteUrl}/favicon.svg`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1312 17th St',
    addressLocality: 'Denver',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 39.7508,
    longitude: -104.9965,
  },
  department: {
    '@type': 'MentalHealthBusiness',
    name: 'Better Lives Building Tribes - Colorado Springs',
    telephone: '+1-720-295-1508',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '10088 Thrive Ln',
      addressLocality: 'Colorado Springs',
      addressRegion: 'CO',
      postalCode: '80924',
      addressCountry: 'US',
    },
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '10:00:00',
      closes: '19:00:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Friday',
      opens: '10:00:00',
      closes: '17:00:00',
    },
  ],
  founder: {
    '@type': 'Person',
    name: 'Dr. Meaghan Rice',
    jobTitle: 'PsyD, LPC, NBCC, ACS',
  },
  sameAs: [
    'https://www.facebook.com/BetterLivesBuildingTribes',
    'https://x.com/betterlivesb',
    'https://www.instagram.com/dr_meaghan/',
    'https://www.tiktok.com/@dr_meaghan',
    'https://www.youtube.com/@dr.meaghan2354',
  ],
};

const allSchemas = [localBusiness, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Structured Data -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Fonts: self-hosted Open Sans -->
    <link rel="preload" href="/fonts/open-sans-variable.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';

  @font-face {
    font-family: 'Open Sans';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('/fonts/open-sans-variable.woff2') format('woff2');
  }

  @font-face {
    font-family: 'Open Sans';
    font-style: italic;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/open-sans-italic.woff') format('woff');
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 100%;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-family);
    font-size: var(--font-size-base);
    line-height: var(--line-height-base);
    color: var(--color-text);
    background-color: var(--color-white);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1, h2, h3, h4, h5, h6 {
    color: var(--color-heading);
    font-weight: var(--font-weight-bold);
    line-height: 1.3;
  }

  h1 { font-size: var(--font-size-3xl); }
  h2 { font-size: var(--font-size-2xl); }
  h3 { font-size: var(--font-size-xl); }
  h4 { font-size: var(--font-size-lg); }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  a:hover {
    color: var(--color-teal);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--color-teal);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    z-index: 1000;
    font-size: var(--font-size-sm);
  }

  .skip-link:focus {
    top: 1rem;
    color: var(--color-white);
  }
</style>
