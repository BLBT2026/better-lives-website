---
interface Props {
  title: string;
  date: Date;
  excerpt?: string;
  slug: string;
  category?: string;
}

const { title, date, excerpt, slug, category } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card">
  {category && <span class="blog-card__category">{category}</span>}
  <h3 class="blog-card__title">
    <a href={`/blog/${slug}`}>{title}</a>
  </h3>
  <time class="blog-card__date" datetime={date.toISOString()}>{formattedDate}</time>
  {excerpt && <p class="blog-card__excerpt">{excerpt}</p>}
</article>

<style>
  .blog-card {
    background: var(--color-white);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-normal);
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
  }

  .blog-card__category {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .blog-card__title {
    font-size: var(--font-size-md);
    margin-bottom: 0.5rem;
  }

  .blog-card__title a {
    color: var(--color-heading);
    text-decoration: none;
  }

  .blog-card__title a:hover {
    color: var(--color-primary);
  }

  .blog-card__date {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .blog-card__excerpt {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--color-text);
  }
</style>
