  }

  .blog-post__footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-gray-bg);
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
  }
</style>
