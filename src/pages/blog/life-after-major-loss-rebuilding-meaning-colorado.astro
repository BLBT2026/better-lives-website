<PageLayout title={`${title} | Better Lives Building Tribes`} schema={schema} description="Everything changed when you experienced your loss. Maybe it was a death, a divorce, a health crisis, the end of a career, or the loss of a dream you carried for years. Whatever it was, the life you ha">
  <Section padding="lg">
    <article class="blog-post">
      <header class="blog-post__header">
        <span class="blog-post__category">{category}</span>
        <h1>{title}</h1>
        <time class="blog-post__date" datetime={date}>
