---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import BlogFilter from '../../components/blog/BlogFilter';
import postsData from '../../data/posts.json';
import '../../components/blog/BlogFilter.css';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/blog/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const siteUrl = 'https://betterlivesbuildingtribes.com';

const posts = postsData.map((post) => {
  let imageUrl: string | undefined;
  if (post.image) {
    const key = Object.keys(imageModules).find((k) => k.includes(post.image!.replace('blog/', '')));
    if (key) {
      imageUrl = imageModules[key].default.src;
    }
  }
  return { ...post, imageUrl };
});

const blogSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Blog',
    description: 'Articles on mental health, therapy, relationships, and wellness from Better Lives Building Tribes.',
    url: `${siteUrl}/blog`,
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: postsData.length,
      itemListElement: postsData.slice(0, 20).map((post, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${siteUrl}/blog/${post.slug}`,
        name: post.title,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog' },
    ],
  },
];
---

<PageLayout
  title="Blog | Better Lives Building Tribes"
  description="Explore articles on mental health, therapy, relationships, and wellness from Better Lives Building Tribes."
  schema={blogSchema}
>
  <div class="blog-banner">
    <div class="blog-banner__inner">
      <h1>Blog</h1>
      <p>Explore our articles on mental health, therapy, and building resilience.</p>
    </div>
  </div>

  <Section background="gray" padding="sm">
    <BlogFilter posts={posts} client:load />
  </Section>
</PageLayout>

<style>
  .blog-banner {
    background-color: var(--color-teal);
    padding: 1.5rem 0;
  }

  .blog-banner__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    text-align: center;
  }

  .blog-banner h1 {
    color: var(--color-white);
    font-size: var(--font-size-2xl);
    margin-bottom: 0.2rem;
  }

  .blog-banner p {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--font-size-sm);
  }
</style>
