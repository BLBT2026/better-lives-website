const date = "2025-07-21";
const category = "Article";
---

<PageLayout title={`${title} | Better Lives Building Tribes`} description="You swore you would never parent the way you were parented. You would be patient, present, and emotionally available. You would not yell, shame, or dismiss your child's feelings like your parents did ">
  <Section padding="lg">
    <article class="blog-post">
      <header class="blog-post__header">
        <span class="blog-post__category">{category}</span>
        <h1>{title}</h1>
        <time class="blog-post__date" datetime={date}>
          {new Date(date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
