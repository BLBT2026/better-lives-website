---

<PageLayout title={`${title} | Better Lives Building Tribes`} description="You moved to a new city, joined a new group, or started trying to make friends. But everyone already has their people. They have inside jokes, history, and established dynamics. You feel like an outsi">
  <Section padding="lg">
    <article class="blog-post">
      <header class="blog-post__header">
        <span class="blog-post__category">{category}</span>
        <h1>{title}</h1>
        <time class="blog-post__date" datetime={date}>
          {new Date(date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
