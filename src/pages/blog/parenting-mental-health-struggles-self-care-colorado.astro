<PageLayout title={`${title} | Better Lives Building Tribes`} description="You are struggling with anxiety, depression, or trauma. But you are also a parent. You have to keep showing up for your kids even when you can barely show up for yourself. You feel guilty. You worry a">
  <Section padding="lg">
    <article class="blog-post">
      <header class="blog-post__header">
        <span class="blog-post__category">{category}</span>
        <h1>{title}</h1>
        <time class="blog-post__date" datetime={date}>
          {new Date(date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
