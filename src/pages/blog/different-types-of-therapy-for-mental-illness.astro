const title = "What Are the Different Types of Therapy for Mental Illness?";
const date = "2024-11-18";
const category = "Health Care";
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    datePublished: date,
    dateModified: date,
  image: 'https://betterlivesbuildingtribes.com/_astro/mental-illness.jpg',
    author: {
      '@type': 'Person',
      name: 'Dr. Meaghan Rice',
      jobTitle: 'PsyD, LPC',
      url: 'https://betterlivesbuildingtribes.com/about',
    },
    publisher: {
      '@type': 'Organization',
      name: 'Better Lives Building Tribes',
      url: 'https://betterlivesbuildingtribes.com',
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `https://betterlivesbuildingtribes.com/blog/different-types-of-therapy-for-mental-illness`,
    },
    articleSection: category,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://betterlivesbuildingtribes.com' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://betterlivesbuildingtribes.com/blog' },
