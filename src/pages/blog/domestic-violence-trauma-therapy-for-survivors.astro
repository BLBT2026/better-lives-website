    color: var(--color-text);
  }

  .blog-post__author {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    font-style: italic;
  }

  .blog-post__content {
    line-height: 1.8;
    font-size: var(--font-size-md);
  }

  .blog-post__content :global(h2) {
    color: var(--color-teal);
