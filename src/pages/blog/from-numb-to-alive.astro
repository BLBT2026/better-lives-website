const title = "From Numb to Alive: Reconnecting with Your Emotions After Trauma";
const date = "2025-05-28";
const category = "Trauma &amp; Healing";
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    datePublished: date,
    dateModified: date,
    author: {
      '@type': 'Person',
      name: 'Dr. Meaghan Rice',
      jobTitle: 'PsyD, LPC',
      url: 'https://betterlivesbuildingtribes.com/about',
    },
    publisher: {
      '@type': 'Organization',
      name: 'Better Lives Building Tribes',
      url: 'https://betterlivesbuildingtribes.com',
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `https://betterlivesbuildingtribes.com/blog/from-numb-to-alive`,
    },
    articleSection: category,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://betterlivesbuildingtribes.com' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://betterlivesbuildingtribes.com/blog' },
      { '@type': 'ListItem', position: 3, name: title },
    ],
  },
