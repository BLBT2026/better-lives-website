const date = "2025-05-14";
const category = "Belonging &amp; Connection";
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    datePublished: date,
    dateModified: date,
    author: {
      '@type': 'Person',
