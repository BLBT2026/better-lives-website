<PageLayout title={`${title} | Better Lives Building Tribes`} description="Remote work was supposed to give you freedom and flexibility. And in many ways, it does. You skip the commute. You work in comfortable clothes. You have control over your schedule. But something unexp">
  <Section padding="lg">
    <article class="blog-post">
      <header class="blog-post__header">
        <span class="blog-post__category">{category}</span>
        <h1>{title}</h1>
        <time class="blog-post__date" datetime={date}>
          {new Date(date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
