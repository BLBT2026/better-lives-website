---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import ServiceCard from '../components/cards/ServiceCard.astro';
import TeamMemberCard from '../components/cards/TeamMemberCard.astro';
import { Image } from 'astro:assets';
import { getFeaturedServices } from '../data/services';
import { teamMembers } from '../data/team';

import heroIllustration from '../assets/images/illustrations/psychologist-illustration-01-1.png';
import aboutPhoto from '../assets/images/general/mrice_320x400.jpeg';
import partnerImg from '../assets/images/hero/Welcome-to-the-Better-Lives-510x382.jpg';

const featuredServices = getFeaturedServices();

const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Better Lives Building Tribes',
  url: 'https://betterlivesbuildingtribes.com',
};
const previewTeam = teamMembers.slice(0, 6);

const testimonials = [
  { name: 'Emily Roberts', quote: 'Dr. Rice is amazing and she helped me through so much!' },
  { name: 'James Anderson', quote: "Meaghan was great and got me on the right track to facing some of my issues head on. I really appreciated her insight." },
  { name: 'Sophia Martinez', quote: 'Meaghan has been amazing and I would highly recommend her!' },
  { name: 'David Clark', quote: "I enjoyed working with my therapist. Great communication and questions to get me thinking." },
  { name: 'Olivia Scott', quote: "She's been really great and has helped me through a lot of issues! I'm very appreciative of our time together." },
  { name: 'Michael Bennett', quote: "Meaghan has been very helpful over these last two years. I've come a long way. I'm grateful for her help." },
  { name: 'Ava Thompson', quote: "Dr. Rice has been great. This has been a very difficult time for me and it was so reassuring to have her support." },
  { name: 'Liam Turner', quote: "Dr. Rice is just wonderful. She really listens and has thoughtful expert input. I cannot speak highly enough of her." },
];
---

<PageLayout title="Home | Better Lives Building Tribes" schema={homeSchema}>
  <Section background="cream" padding="lg">
    <div class="hero">
      <div class="hero__text">
        <h1>Better Lives Building Tribes</h1>
        <p>
          Better Lives Building Tribes brings people, organizations, and communities
          together to strengthen relationships, support well-being, and build resilience
          that lasts. Through collaboration, education, and evidence-informed practice, we
          help individuals and systems create healthier connections and meaningful change.
        </p>
        <Button href="/schedule" variant="primary" size="lg">Schedule a Consultation</Button>
      </div>
      <div class="hero__image">
        <Image src={heroIllustration} alt="Therapy illustration" width={420} height={420} />
      </div>
    </div>
  </Section>

  <Section padding="lg">
    <div class="centered">
      <h2>You Don't Have To Suffer Any Longer</h2>
      <p>
        We provide compassionate, evidence-informed therapy services for individuals,
        couples, and families throughout Colorado. Our diverse team of licensed therapists
        is here to support you on your journey toward healing and growth.
      </p>
    </div>
  </Section>

  <Section background="gray" padding="lg">
    <h2 class="section-heading">Our Services</h2>
    <div class="services-grid">
      {featuredServices.map((service) => (
        <ServiceCard title={service.title} summary={service.summary} slug={service.slug} />
      ))}
    </div>
    <div class="centered" style="margin-top: var(--space-lg);">
      <Button href="/services" variant="outline">View All Services</Button>
    </div>
  </Section>

  <Section padding="lg">
    <div class="about-preview">
      <div class="about-preview__image">
        <Image src={aboutPhoto} alt="Dr. Meaghan Rice" width={320} height={400} />
      </div>
      <div class="about-preview__text">
        <h2>Dr. Meaghan Rice, PsyD, LPC</h2>
        <p>
          The driving force behind Better Lives Building Tribes, Dr. Rice has been helping
          people change their lives for over ten years. Her method combines evidence-informed
          approaches with practical application to help individuals, couples, and families
          build resilience and create meaningful change.
        </p>
        <Button href="/about" variant="secondary">About Dr. Rice</Button>
      </div>
    </div>
  </Section>

  <Section background="cream" padding="lg">
    <h2 class="section-heading">Meet Our Team</h2>
    <div class="team-grid">
      {previewTeam.map((member) => (
        <TeamMemberCard
          name={member.name}
          title={member.title}
          license={member.license}
          licensedIn={member.licensedIn}
          photo={member.photo}
          pronouns={member.pronouns}
        />
      ))}
    </div>
    <div class="centered" style="margin-top: var(--space-lg);">
      <Button href="/our-team" variant="outline">View Full Team</Button>
    </div>
  </Section>

  <Section background="teal" padding="lg">
    <h2 class="section-heading" style="color: var(--color-white);">What Our Clients Say</h2>
    <div class="testimonials">
      {testimonials.map((t) => (
        <blockquote class="testimonial">
          <p>&ldquo;{t.quote}&rdquo;</p>
          <cite>&mdash; {t.name}</cite>
        </blockquote>
      ))}
    </div>
  </Section>

  <Section padding="lg" id="partners">
    <div class="partners">
      <div class="partners__image">
        <Image src={partnerImg} alt="Partner with Better Lives Building Tribes" width={510} height={382} />
      </div>
      <div class="partners__text">
        <h2>Partner With Better Lives Building Tribes</h2>
        <p>
          We work with organizations and communities to strengthen relationships,
          support well-being, and build resilience. Let's create meaningful change together.
        </p>
        <Button href="/contact" variant="primary">Get in Touch</Button>
      </div>
    </div>
  </Section>

  <Section background="cream" padding="lg">
    <div class="centered">
      <h2>Ready to Take the First Step?</h2>
      <p>Schedule a free consultation and find out how we can help.</p>
      <Button href="/schedule" variant="primary" size="lg">Schedule a Free Consultation</Button>
    </div>
  </Section>
</PageLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }

  .hero__text {
    flex: 1;
  }

  .hero__text h1 {
    font-size: var(--font-size-4xl);
    color: var(--color-teal);
    margin-bottom: var(--space-md);
  }

  .hero__text p {
    font-size: var(--font-size-md);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .hero__image {
    flex-shrink: 0;
  }

  .hero__image :global(img) {
    border-radius: var(--radius-lg);
  }

  .centered {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .centered h2 {
    color: var(--color-teal);
    margin-bottom: var(--space-md);
  }

  .centered p {
    font-size: var(--font-size-md);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .section-heading {
    text-align: center;
    color: var(--color-teal);
    margin-bottom: var(--space-xl);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .about-preview {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }

  .about-preview__image :global(img) {
    border-radius: var(--radius-md);
  }

  .about-preview__text {
    flex: 1;
  }

  .about-preview__text h2 {
    color: var(--color-teal);
    margin-bottom: var(--space-sm);
  }

  .about-preview__text p {
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .testimonials {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .testimonial {
    background: rgba(255, 255, 255, 0.1);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-rose);
  }

  .testimonial p {
    color: var(--color-white);
    font-style: italic;
    line-height: 1.7;
    margin-bottom: var(--space-xs);
  }

  .testimonial cite {
    color: var(--color-cream);
    font-size: var(--font-size-sm);
    font-style: normal;
    font-weight: var(--font-weight-medium);
  }

  .partners {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }

  .partners__image :global(img) {
    border-radius: var(--radius-md);
  }

  .partners__text {
    flex: 1;
  }

  .partners__text h2 {
    color: var(--color-teal);
    margin-bottom: var(--space-sm);
  }

  .partners__text p {
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 980px) {
    .hero {
      flex-direction: column;
      text-align: center;
    }

    .hero__image {
      order: -1;
    }

    .hero__image :global(img) {
      max-width: 280px;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .about-preview,
    .partners {
      flex-direction: column;
      text-align: center;
    }

    .testimonials {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .team-grid {
      grid-template-columns: 1fr;
    }

    .hero__text h1 {
      font-size: var(--font-size-2xl);
    }
  }
</style>
