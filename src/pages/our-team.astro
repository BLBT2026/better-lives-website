---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import TeamMemberCard from '../components/cards/TeamMemberCard.astro';
import { teamMembers } from '../data/team';
---

<PageLayout
  title="Our Team | Better Lives Building Tribes"
  description="Meet our diverse team of licensed therapists dedicated to helping you build resilience and find fulfillment."
>
  <Section padding="lg">
    <div class="page-header">
      <h1>Our Team</h1>
      <p>
        At Better Lives Building Tribes, we create a valued space for all. Our diverse team
        fosters connections that empower authenticity. We are a community dedicated to
        collaboration and growth. With compassion and innovation, we guide your transformation,
        helping you build resilience and find fulfillment.
      </p>
      <Button href="/schedule" variant="primary">Book</Button>
    </div>
  </Section>

  <Section background="gray" padding="lg">
    <div class="team-grid">
      {teamMembers.map((member) => (
        <TeamMemberCard
          name={member.name}
          title={member.title}
          license={member.license}
          licensedIn={member.licensedIn}
          photo={member.photo}
          pronouns={member.pronouns}
        />
      ))}
    </div>
  </Section>

  <Section background="cream" padding="lg">
    <div class="cta">
      <h2>Schedule a Free Consultation</h2>
      <p>Find the right therapist for your needs. We're here to help.</p>
      <Button href="/schedule" variant="primary" size="lg">Schedule Now</Button>
    </div>
  </Section>
</PageLayout>

<style>
  .page-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .page-header h1 {
    color: var(--color-teal);
    margin-bottom: var(--space-md);
  }

  .page-header p {
    font-size: var(--font-size-md);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .cta {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta h2 {
    color: var(--color-teal);
    margin-bottom: var(--space-sm);
  }

  .cta p {
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 980px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
