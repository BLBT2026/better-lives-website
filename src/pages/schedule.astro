---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import CalendlyEmbed from '../components/forms/CalendlyEmbed.astro';
---

<PageLayout
  title="Schedule | Better Lives Building Tribes"
  description="Schedule a free 30-minute consultation with Better Lives Building Tribes."
>
  <Section padding="sm">
    <div class="schedule-header">
      <h1>Schedule a Consultation</h1>
      <p>Book a free 30-minute consultation to discuss your needs and find the right therapist for you.</p>
    </div>
  </Section>

  <Section padding="sm">
    <CalendlyEmbed />
  </Section>

  <Section background="cream" padding="md">
    <div class="schedule-fallback">
      <p>
        Having trouble with the scheduler? Contact us directly at
        <a href="tel:7202951508">(720) 295-1508</a> or
        <a href="mailto:BetterLives.BuildingTribes@gmail.com">BetterLives.BuildingTribes@gmail.com</a>
      </p>
    </div>
  </Section>
</PageLayout>

<style>
  .schedule-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .schedule-header h1 {
    color: var(--color-teal);
    margin-bottom: var(--space-xs);
  }

  .schedule-header p {
    line-height: 1.7;
  }

  .schedule-fallback {
    text-align: center;
    font-size: var(--font-size-sm);
  }

  .schedule-fallback a {
    font-weight: var(--font-weight-medium);
  }
</style>
