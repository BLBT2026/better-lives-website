---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import Section from '../../components/ui/Section.astro';
---

<ServiceLayout
  title="Divorce or Breakup Therapy"
  description="Navigate divorce or breakup with support. Process grief, rebuild identity, and move forward with clarity and hope."
>
  <Section background="cream" padding="md">
    <div class="detail">
      <p>
        At Better Lives Building Tribes, we offer this service as part of our comprehensive
        approach to mental health and wellness. Our licensed therapists are trained in
        evidence-based methods to provide you with the highest quality of care.
      </p>
      <p>
        Navigate divorce or breakup with support. Process grief, rebuild identity, and move forward with clarity and hope.
      </p>
    </div>
  </Section>
</ServiceLayout>

<style>
  .detail {
    max-width: 720px;
    margin: 0 auto;
  }

  .detail p {
    font-size: var(--font-size-md);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }
</style>
